    <function name="Main" type="None" variable="">
        <parameters/>
        <body>
            <declare name="uch" type="Integer" array="False" size=""/>
            <declare name="yuz" type="Integer" array="False" size=""/>
            <declare name="on" type="Integer" array="False" size=""/>
            <declare name="b" type="Integer" array="False" size=""/>
            <declare name="y" type="Integer" array="False" size=""/>
            <input variable="uch"/>
            <assign variable="yuz" expression="uch/100"/>
            <assign variable="b" expression="uch%10"/>
            <assign variable="on" expression="(uch-(yuz*100)-b)/10"/>
            <assign variable="y" expression="yuz+b+on"/>
            <output expression="y" newline="True"/>
        </body>
    </function>
</flowgorithm>
