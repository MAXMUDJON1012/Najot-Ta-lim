                        </then>
                        <else>
                            <if expression="t&lt;70">
                                <then>
                                    <output expression="&quot;qoniqarli&quot;" newline="True"/>
                                </then>
                                <else>
                                    <if expression="t&lt;85">
                                        <then>
                                            <output expression="&quot;yaxshi&quot;" newline="True"/>
                                        </then>
                                        <else>
                                            <output expression="&quot;alo&quot;" newline="True"/>
                                        </else>
                                    </if>
                                </else>
                            </if>
