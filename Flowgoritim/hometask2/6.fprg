    <function name="Main" type="None" variable="">
        <parameters/>
        <body>
            <declare name="t" type="Integer" array="False" size=""/>
            <if expression="t&gt;100">
                <then>
                    <output expression="&quot;bunday ball yoq&quot;" newline="True"/>
                </then>
                <else>
                    <if expression="t&lt;50">
                        <then>
